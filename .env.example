# LiveCaptionIt env vars.
#
# 99% of the time you need NOTHING in this file — every value has a
# sensible production default baked into src/site.config.ts. Copy this to
# .env (gitignored) only if you want to override something locally.
#
# All public vars must start with PUBLIC_ to reach client code.
#
# ─────────────────────────────────────────────────────────────────────────
# ABSOLUTE MUST-SET on Cloudflare Pages dashboard (Production env vars):
# ─────────────────────────────────────────────────────────────────────────
#
#   NODE_VERSION=22
#
# That's the only thing CF itself doesn't infer correctly. Astro needs
# Node ≥22.12 to build; CF's default Node is too old and the build
# silently fails without this.
#
# Everything else (including the GA4 measurement ID) has a hardcoded
# production default that ships with the repo and is correct for
# livecaptionit.com.
#
# ─────────────────────────────────────────────────────────────────────────
# OPTIONAL overrides (only set if you actually need to override the
# default — leave unset on Cloudflare otherwise):
# ─────────────────────────────────────────────────────────────────────────
#
# PUBLIC_GA_MEASUREMENT_ID=G-XZPZ13FET6
#   GA4 measurement ID. Default is the livecaptionit.com production
#   property (G-XZPZ13FET6) baked into src/site.config.ts. Override only
#   when running a fork that needs its own property. Set to empty string
#   to disable analytics entirely. PROD-gated — never fires on local dev.
#
# PUBLIC_SITE_URL=https://livecaptionit.com
#   Override canonical URL. Sitemap/OG meta use this. The build defends
#   itself: if PUBLIC_SITE_URL points at a *.pages.dev preview, it's
#   silently coerced back to livecaptionit.com so previews don't leak
#   broken canonicals into Google.
#
# PUBLIC_SITE_DOMAIN=livecaptionit.com
# PUBLIC_SITE_NAME=LiveCaptionIt
# PUBLIC_SITE_SHORT_NAME=LiveCaptionIt
# PUBLIC_SITE_TAGLINE=Live captions for any tab. Floats over anything. Never uploads.
# PUBLIC_SITE_DESCRIPTION=Live captions for any audio your browser can hear — YouTube, podcasts, web meetings, lectures. Floats in a picture-in-picture window over any app. Runs Whisper locally in your browser via WebGPU. Audio never uploads.
# PUBLIC_BASE_PATH=/
# PUBLIC_GITHUB_URL=https://github.com/shrestha-tripathi/livecaptionit
# PUBLIC_SITE_AUTHOR=Shrestha Tripathi
# PUBLIC_SITE_CONTACT_EMAIL=shrestha.tripathi@gmail.com
# PUBLIC_SITE_JURISDICTION=India
# PUBLIC_SITE_LOCALE=en
#
# ─────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS (build-time toggles — see docs/BUILD_FLAGS.md for details
# and parsing rules). All default to `false`. Leave unset in production.
# ─────────────────────────────────────────────────────────────────────────
#
# PUBLIC_ALLOW_MOBILE_WEBGPU=false
#   Default false. When true, mobile devices (iOS Safari, Chrome Android)
#   attempt WebGPU for Whisper inference instead of being force-locked to
#   WASM. WebGPU on mobile is technically present (iOS Safari 18.2+,
#   Chrome Android 121+) but still hangs / OOMs / crashes on enough
#   devices that we keep production on WASM. Flip to `true` only for
#   testing — visit /?debug=1 on the phone to confirm the flag took
#   effect ("flag PUBLIC_ALLOW_MOBILE_WEBGPU: true" appears in the
#   debug panel).
