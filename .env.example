# Copy to .env (gitignored) for local overrides.
# All public vars must start with PUBLIC_ to reach client code.

# Used for canonical URLs, OG meta, sitemap.xml. Cloudflare Pages sets these
# in the dashboard for production. Local default falls through to captionpip.com.
PUBLIC_SITE_URL=https://captionpip.com
PUBLIC_SITE_DOMAIN=captionpip.com

# Brand strings — single source of truth.
PUBLIC_SITE_NAME=CaptionPip
PUBLIC_SITE_SHORT_NAME=CaptionPip
PUBLIC_SITE_TAGLINE=Live captions for any tab. Floats over anything. Never uploads.
PUBLIC_SITE_DESCRIPTION=Live captions for any audio your browser can hear — YouTube, podcasts, web meetings, lectures. Floats in a picture-in-picture window over any app. Runs Whisper locally in your browser via WebGPU. Audio never uploads.

# Astro base path. "/" for production, "/captionpip/" if hosted under a subpath.
PUBLIC_BASE_PATH=/

# GitHub repo URL (footer link). Leave blank to hide.
PUBLIC_GITHUB_URL=https://github.com/shrestha-tripathi/captionpip

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX). Leave blank to
# disable analytics entirely. Snippet only injected in production builds.
PUBLIC_GA_MEASUREMENT_ID=

# Trust pages — used by About / Contact / Privacy / Terms + JSON-LD.
PUBLIC_SITE_AUTHOR=Shrestha Tripathi
PUBLIC_SITE_CONTACT_EMAIL=shrestha.tripathi@gmail.com
PUBLIC_SITE_JURISDICTION=India
PUBLIC_SITE_LOCALE=en
