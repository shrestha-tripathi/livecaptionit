---
import Layout from "../layouts/Layout.astro";
import { site, b } from "../site.config";
import { breadcrumb } from "../lib/breadcrumb";

const howToLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: `How to add free live captions to Google Meet with ${site.name}`,
  description:
    "Free live captions for Google Meet — works on any Google Workspace plan, including personal Gmail accounts. Captions float above the meeting.",
  totalTime: "PT30S",
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Join the Google Meet in your browser",
      text: "Open meet.google.com/<meeting-code> in Chrome / Edge / Brave. (Google Meet is browser-only by default — no native app to worry about.)",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: `Open ${site.name} in another tab`,
      text: `Visit ${site.domain} in a second tab. Click "Start captions".`,
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Share the Meet tab + tick 'Share tab audio'",
      text: "Browser picker opens — pick your Google Meet tab and tick 'Share tab audio' at the bottom. Without it, only video is shared, no audio.",
    },
    {
      "@type": "HowToStep",
      position: 4,
      name: "Switch back to Meet",
      text: "Floating PiP caption window appears. Switch back to the Meet tab. Captions update in real time, visible no matter which app you switch to.",
    },
  ],
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Why use this when Google Meet has captions built in?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Google Meet's native captions are good but limited to Google's supported language list and locked to certain Workspace plans. ${site.name} captions any Meet call on any account — including free personal Gmail — supports 99 languages via Whisper, and adds a floating Picture-in-Picture window so you can read captions while doing something else in another tab or app.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Does Google Meet know I'm using third-party captions?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>No. ${site.name} captures the tab audio locally in your browser, runs Whisper on your device's GPU, and renders captions on your own screen. Meet sees no different activity from a normal participant. No plugin, no extension, no bot joining the call.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Can I caption a Meet call recorded in Drive after the fact?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Yes if you can play the recording in a Chrome tab. Open the recording from Google Drive, share the tab with audio in ${site.name}, hit play. Live captions appear, and you can download the transcript as .txt / .vtt / .srt afterward. Useful when Google's native auto-transcription doesn't cover your call or language.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Will the captions show up for other Meet participants?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>No. Captions are rendered only on your own screen — Meet doesn't know about ${site.name}, and the floating window is your local browser's PiP API. Other participants see the meeting normally. If you want everyone to see captions, enable Meet's native captions for the call (their per-participant on/off doesn't affect you).</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Can I caption a Meet call I'm joining from my phone?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Mobile browsers don't support tab audio capture, so caption-the-Meet-tab won't work on a phone. ${site.name}'s microphone mode does work on mobile — point your phone's mic at the speaker playing the Meet audio (or use a wired/Bluetooth speakerphone). Captions appear inline on your phone. Better still, join from a laptop where tab capture works natively.</p>`,
      },
    },
  ],
};

const bc = breadcrumb({ name: "Live captions for Google Meet", path: "/captions-for-google-meet" });
---

<Layout
  title="Free live captions for Google Meet — any plan, any language"
  description={`Free live captions for Google Meet on any Workspace plan, including personal Gmail. 99-language Whisper support. Floating window above the meeting. Nothing uploads.`}
  jsonLd={[howToLd, faqLd, bc]}
>
  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <p class="text-xs text-[var(--color-fg-subtle)] mb-3">
      <a href={b("/")} class="hover:text-[var(--color-fg)]">{site.name}</a>
      <span class="mx-1.5">/</span>
      <span>Live captions for Google Meet</span>
    </p>

    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">
      Free live captions for Google Meet.
    </h1>
    <p class="text-lg text-[var(--color-fg-muted)] mb-8">
      Any Workspace plan. Any language Whisper supports (99 of them).
      Floating Picture-in-Picture window above the meeting itself. Free, no
      signup, audio stays on your device.
    </p>

    <div class="mb-12">
      <a
        href={b("/")}
        class="brand-halo inline-flex items-center gap-2 px-6 py-3 rounded-full text-base font-semibold bg-[var(--color-brand)] text-white hover:bg-[var(--color-brand-strong)] transition-colors shadow-line"
      >
        Start captioning →
      </a>
      <p class="mt-3 text-xs text-[var(--color-fg-subtle)]">
        Free · any Workspace plan · invisible to the meeting
      </p>
    </div>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Step-by-step</h2>
      <ol class="space-y-4">
        {howToLd.step.map((s, i) => (
          <li class="flex gap-4">
            <span class="shrink-0 size-7 grid place-items-center rounded-full bg-[var(--color-brand)] text-white font-bold text-sm">{i + 1}</span>
            <div>
              <p class="font-semibold text-[var(--color-fg)]">{s.name}</p>
              <p class="mt-1 text-sm text-[var(--color-fg-muted)] leading-relaxed">{s.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Meet captions vs {site.name}</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--color-border)]">
              <th class="text-left p-3 font-semibold text-[var(--color-fg-muted)]"> </th>
              <th class="text-left p-3 font-semibold text-[var(--color-fg-muted)]">Meet built-in</th>
              <th class="text-left p-3 font-semibold text-[var(--color-brand-strong)]">{site.name}</th>
            </tr>
          </thead>
          <tbody class="text-[var(--color-fg-muted)]">
            <tr class="border-b border-[var(--color-border)]"><td class="p-3 font-medium text-[var(--color-fg)]">Plan needed</td><td class="p-3">Workspace plans only</td><td class="p-3 text-[var(--color-fg)]">Any (including free Gmail)</td></tr>
            <tr class="border-b border-[var(--color-border)]"><td class="p-3 font-medium text-[var(--color-fg)]">Floating window</td><td class="p-3">✗ Inside meeting only</td><td class="p-3 text-[var(--color-fg)]">✓ PiP, any app</td></tr>
            <tr class="border-b border-[var(--color-border)]"><td class="p-3 font-medium text-[var(--color-fg)]">Languages</td><td class="p-3">~15 (varies by plan)</td><td class="p-3 text-[var(--color-fg)]">99 (Whisper)</td></tr>
            <tr class="border-b border-[var(--color-border)]"><td class="p-3 font-medium text-[var(--color-fg)]">Privacy</td><td class="p-3">Sent to Google</td><td class="p-3 text-[var(--color-fg)]">Local-only, no upload</td></tr>
            <tr><td class="p-3 font-medium text-[var(--color-fg)]">Transcript download</td><td class="p-3">Plan-dependent</td><td class="p-3 text-[var(--color-fg)]">Always (.txt/.vtt/.srt)</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Common questions</h2>
      <div class="space-y-2">
        {faqLd.mainEntity.map((q) => (
          <details class="group bg-[var(--color-surface)] rounded-md px-4 py-3 shadow-line">
            <summary class="cursor-pointer font-semibold text-[var(--color-fg)] flex items-center justify-between gap-3">
              <span>{q.name}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9" /></svg>
            </summary>
            <div class="mt-2 text-sm text-[var(--color-fg-muted)] [&_p]:mt-2 [&_p:first-child]:mt-0" set:html={q.acceptedAnswer.text}></div>
          </details>
        ))}
      </div>
    </section>

    <section class="mb-12 p-6 rounded-xl bg-[var(--color-surface)] shadow-line">
      <h2 class="text-xl font-bold mb-2">Caption your next Meet call</h2>
      <p class="text-sm text-[var(--color-fg-muted)] mb-4">
        Any Google account. Floating window. Audio never uploads.
      </p>
      <a
        href={b("/")}
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold bg-[var(--color-brand)] text-white hover:bg-[var(--color-brand-strong)] transition-colors shadow-line"
      >
        Open {site.name} →
      </a>
    </section>
  </main>
</Layout>
