---
import Layout from "../layouts/Layout.astro";
import { site, b } from "../site.config";
import { breadcrumb } from "../lib/breadcrumb";

const howToLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: `How to live-caption a podcast with ${site.name}`,
  description:
    "Add live captions to any podcast playing in your browser — Spotify Web, Apple Podcasts Web, YouTube podcasts, Pocket Casts. Captions float above other apps so you can read while doing something else.",
  totalTime: "PT30S",
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Open the podcast in a browser tab",
      text: "Spotify Web (open.spotify.com), Apple Podcasts Web, YouTube podcast video, Pocket Casts Web, Overcast Web — anywhere the podcast plays in Chrome.",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: `Open ${site.name} in another tab`,
      text: `Visit ${site.domain} and click "Start captions".`,
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Share the podcast tab + tick 'Share tab audio'",
      text: "Pick the podcast tab in the browser picker. Tick 'Share tab audio' at the bottom.",
    },
    {
      "@type": "HowToStep",
      position: 4,
      name: "Press play, read along",
      text: "Floating caption window appears. Press play on the podcast. Read captions in PiP while doing chores, taking notes, or following a recipe.",
    },
  ],
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Why caption a podcast when transcripts exist?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Most podcasts release transcripts <em>after</em> publication, if at all. Live captioning lets you follow along in real time — useful for noisy environments (gym, commute, public space), accessibility (hearing assistance, English-as-second-language), or quickly skimming a long podcast for a specific topic.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Will Spotify or Apple Podcasts let me share tab audio?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Yes — Spotify Web (open.spotify.com), Apple Podcasts Web, Pocket Casts Web, and Overcast Web all stream audio through the browser tab in standard ways. Chrome's tab capture works on all of them. The native desktop apps (Spotify desktop, Apple Podcasts app) bypass the browser so ${site.name} can't see their audio — use the web version instead.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Can I caption a podcast in a foreign language?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Yes — Whisper supports 99 languages out of the box and ${site.name} uses its multilingual mode automatically. Spanish, Hindi, Tamil, Mandarin, Japanese, etc. all work. Captions appear in the source language. For best accuracy on a specific language, the Custom Vocabulary panel lets you pre-load common terms.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "How accurate is podcast captioning vs YouTube auto-CC?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Whisper Base (default) is roughly comparable to YouTube auto-CC for clean conversational English — about 95% accurate. For heavy accents, multiple speakers, or technical jargon, the Small or Large turbo model tiers do better. The trade-off is download size (244 MB and 537 MB respectively) and slightly higher GPU load.</p>`,
      },
    },
  ],
};

const bc = breadcrumb({ name: "Live captions for podcasts", path: "/podcast-captions" });
---

<Layout
  title="Live captions for any podcast — Spotify Web, Apple, YouTube"
  description={`Live captions for podcasts in your browser — Spotify Web, Apple Podcasts Web, YouTube, Pocket Casts. Floats over other apps. Free, no signup, nothing uploads.`}
  jsonLd={[howToLd, faqLd, bc]}
>
  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <p class="text-xs text-[var(--color-fg-subtle)] mb-3">
      <a href={b("/")} class="hover:text-[var(--color-fg)]">{site.name}</a>
      <span class="mx-1.5">/</span>
      <span>Live captions for podcasts</span>
    </p>

    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">
      Live captions for any podcast.
    </h1>
    <p class="text-lg text-[var(--color-fg-muted)] mb-8">
      Spotify Web, Apple Podcasts, YouTube podcasts, Pocket Casts — any podcast
      playing in your browser, captioned in real time. Floats over other apps
      so you can read while doing chores, commuting, or working out. Free,
      nothing uploads.
    </p>

    <div class="mb-12">
      <a
        href={b("/")}
        class="brand-halo inline-flex items-center gap-2 px-6 py-3 rounded-full text-base font-semibold bg-[var(--color-brand)] text-white hover:bg-[var(--color-brand-strong)] transition-colors shadow-line"
      >
        Start captioning →
      </a>
      <p class="mt-3 text-xs text-[var(--color-fg-subtle)]">
        Free · no signup · audio processed locally
      </p>
    </div>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Works for podcasts on:</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {[
          "Spotify Web",
          "Apple Podcasts Web",
          "YouTube podcasts",
          "Pocket Casts Web",
          "Overcast Web",
          "Castbox Web",
        ].map((name) => (
          <div class="p-3 rounded-md bg-[var(--color-surface)] shadow-line">
            <p class="font-semibold text-sm text-[var(--color-fg)]">{name}</p>
          </div>
        ))}
      </div>
      <p class="mt-3 text-xs text-[var(--color-fg-subtle)]">
        Note: native desktop podcast apps (Spotify desktop, Apple Podcasts app)
        play audio outside the browser, so tab capture can't see them. Use the
        web version instead.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Step-by-step</h2>
      <ol class="space-y-4">
        {howToLd.step.map((s, i) => (
          <li class="flex gap-4">
            <span class="shrink-0 size-7 grid place-items-center rounded-full bg-[var(--color-brand)] text-white font-bold text-sm">{i + 1}</span>
            <div>
              <p class="font-semibold text-[var(--color-fg)]">{s.name}</p>
              <p class="mt-1 text-sm text-[var(--color-fg-muted)] leading-relaxed">{s.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">Common questions</h2>
      <div class="space-y-2">
        {faqLd.mainEntity.map((q) => (
          <details class="group bg-[var(--color-surface)] rounded-md px-4 py-3 shadow-line">
            <summary class="cursor-pointer font-semibold text-[var(--color-fg)] flex items-center justify-between gap-3">
              <span>{q.name}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9" /></svg>
            </summary>
            <div class="mt-2 text-sm text-[var(--color-fg-muted)] [&_p]:mt-2 [&_p:first-child]:mt-0" set:html={q.acceptedAnswer.text}></div>
          </details>
        ))}
      </div>
    </section>

    <section class="mb-12 p-6 rounded-xl bg-[var(--color-surface)] shadow-line">
      <h2 class="text-xl font-bold mb-2">Caption your next podcast</h2>
      <p class="text-sm text-[var(--color-fg-muted)] mb-4">
        Floating window stays on top while you work, walk, or take notes.
        Audio processed locally. Never uploads.
      </p>
      <a
        href={b("/")}
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold bg-[var(--color-brand)] text-white hover:bg-[var(--color-brand-strong)] transition-colors shadow-line"
      >
        Open {site.name} →
      </a>
    </section>
  </main>
</Layout>
