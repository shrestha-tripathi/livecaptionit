---
import Layout from "../layouts/Layout.astro";
import CaptionApp from "../components/CaptionApp.astro";
import CrossPromo from "../components/CrossPromo.astro";
import { site } from "../site.config";

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How is this different from Chrome's built-in Live Caption?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Chrome's Live Caption is system-only — it doesn't float over other apps and can't show captions in a picture-in-picture window. ${site.name} pops the captions into a floating window that stays visible no matter which app you're using, and works on multiple operating systems (Chrome's Live Caption availability varies by OS).</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Does my audio get uploaded anywhere?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>No. ${site.name} runs the Whisper speech-recognition model directly in your browser via WebGPU and transformers.js. Audio is processed on your device and never sent to any server. The only network requests are the one-time download of the model file from Hugging Face Hub, cached locally afterward.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Does it store anything?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>${site.name} stores your last 20 caption transcripts locally in your browser (IndexedDB) so you can revisit and re-download them from the "Recent sessions" panel on the home page. <strong>Only the text is stored — never the raw audio.</strong> Click "Clear all" anytime to wipe history. Nothing ever leaves your device. Your model preference, caption style, and PiP window size are also saved (localStorage) for convenience.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Can I try it without picking a tab or granting microphone access?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Yes. Click "Try with sample audio · no setup" on the home page. It plays a short bundled audio clip through the same pipeline that captions your real audio — no permission prompts. Useful to see how the rolling-window captions feel, judge whether the model picker tier (tiny/base/small) you've chosen is fast enough on your device, or just confirm everything works before you commit to picking a tab.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Which browsers are supported?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Tab/screen capture mode needs Chrome, Edge, or Brave 116+ on desktop. Microphone-only mode works in all modern browsers (Firefox + Safari included). The floating picture-in-picture window is Chromium-only for now. Mobile browsers don't support screen capture, so ${site.name} is desktop-first.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "How fast are the captions?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>The first word usually appears within ~700ms of speech. ${site.name} uses a rolling-window streaming transcriber: instead of waiting for fixed 3-second chunks, it re-transcribes the recent audio every ~700ms and shows confident words bold + uncertain words muted. Words "solidify in place" as the model becomes confident. Feels like Live Caption / YouTube CC rather than delayed subtitles.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Can I choose between speed and accuracy?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Yes. The Whisper model picker on the home page lets you choose Tiny (39 MB, ~2x faster), Base (74 MB, default — balanced), Small (244 MB, ~10% more accurate but slower), or Large turbo (537 MB, top-tier accuracy — recommended only when smaller tiers can't keep up with your audio). Each model is cached in your browser after the first download. Pick whichever matches your machine + audio quality.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Can I download the transcript?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Yes. After you click Stop, three download buttons appear: .txt (plain text), .vtt (WebVTT, for video players that support subtitles), and .srt (SubRip, the universal subtitle format). Timestamps are at segment level (~700-1200ms granularity) — good enough for most use cases, not for frame-perfect subtitle alignment.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Can I use my microphone instead of a tab?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Yes. Toggle the "Microphone" source on the home page instead of "Tab / window". Useful for dictation, voice notes, recording your own speech for podcast prep, or captioning a meeting where you are the speaker. ${site.name} disables the browser's echo cancellation and auto-gain control for microphone mode so Whisper sees the raw audio.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Can I customize the caption look?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Yes. The "Caption style" panel on the home page lets you adjust font size (80-200%), base font weight (regular / medium / bold), caption position in the floating window (top / middle / bottom), and the text-shadow that boosts legibility when the window sits over bright video. All settings apply live and persist in your browser.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Can it caption audio from a desktop app like Zoom or Spotify?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>On Windows: yes, if you pick "Entire screen" in the source picker and your browser is allowed to capture system audio (Chrome and Edge support this). On macOS and Linux, the browser can only capture audio from another browser tab — so use Zoom Web or Spotify Web instead. macOS users can install BlackHole (free virtual audio device) to route desktop app audio into the browser if needed.</p>`,
      },
    },
    {
      "@type": "Question",
      name: "Can it tell who is speaking? (speaker diarization)",
      acceptedAnswer: {
        "@type": "Answer",
        text: `<p>Not yet — and honestly, it's harder than it sounds in a browser. When you capture a tab, every speaker arrives as one mono audio stream at similar volume, so distinguishing "Speaker A" from "Speaker B" needs a separate voice-fingerprinting model (~300MB) that we haven't shipped to keep ${site.name} fast and lightweight. A future release may split paragraphs on long pauses (a cheap approximation that doesn't claim speaker identity). For now, the transcript is one continuous stream of text.</p>`,
      },
    },
  ],
};
---

<Layout
  title={`Live captions for any tab · picture-in-picture · runs offline`}
  description={site.description}
  jsonLd={[faqJsonLd]}
>
  <main class="pt-10 sm:pt-16 pb-16">
    {/* ─── Hero ─── */}
    <section class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="inline-flex items-center gap-1.5 text-[11px] uppercase tracking-wider font-semibold px-2.5 py-1 rounded-full bg-[var(--color-brand-soft)] shadow-line" style="color: var(--color-brand-strong)">
        <span class="size-1.5 rounded-full" style="background: var(--color-brand)"></span>
        100% local · powered by WebGPU + Whisper
      </p>
      <h1 class="mt-5 text-4xl sm:text-5xl font-bold tracking-tight text-[var(--color-fg)]">
        Live captions for any tab.<br />
        <span class="text-[var(--color-fg-muted)]">Floats over anything.</span>
      </h1>
      <p class="mt-5 text-lg text-[var(--color-fg-muted)] max-w-xl mx-auto">
        Caption a YouTube video, a podcast, a web meeting — anything your browser can hear. The captions pop into a floating window that stays on top no matter what app you switch to.
      </p>
    </section>

    {/* ─── The actual tool ─── */}
    <div class="mt-10 sm:mt-14">
      <CaptionApp />
    </div>

    {/* ─── 3-step explainer ─── */}
    <section class="mt-20 max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold tracking-tight text-center">How it works</h2>
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { n: "1", title: "Click Start", body: "A floating window pops up, and your browser asks which tab, window, or screen to listen to. Tick 'Share tab audio' on the picker." },
          { n: "2", title: "Pick the source", body: "Choose what to caption — a YouTube tab, a podcast, a web meeting. Whisper loads locally in your browser via WebGPU (~75 MB first time, instant after)." },
          { n: "3", title: "Captions float over anything", body: "The floating window stays on top of whatever app you switch to. Close it to bring captions back into this tab." },
        ].map((step) => (
          <div class="bg-[var(--color-surface)] rounded-xl p-5 shadow-line">
            <div class="size-7 grid place-items-center rounded-full font-bold text-xs" style="background: var(--color-brand); color: white">{step.n}</div>
            <h3 class="mt-3 font-semibold text-[var(--color-fg)]">{step.title}</h3>
            <p class="mt-1.5 text-sm text-[var(--color-fg-muted)]">{step.body}</p>
          </div>
        ))}
      </div>
    </section>

    {/* ─── Use cases ─── */}
    <section class="mt-20 max-w-4xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold tracking-tight text-center">When you'd use it</h2>
      <div class="mt-8 grid grid-cols-2 sm:grid-cols-4 gap-3">
        {[
          { icon: "🎓", label: "Lectures & MOOCs" },
          { icon: "💼", label: "Web meetings" },
          { icon: "🎙️", label: "Podcasts" },
          { icon: "🎥", label: "YouTube videos" },
          { icon: "📺", label: "Live streams" },
          { icon: "🌐", label: "Foreign content" },
          { icon: "👂", label: "Hearing accessibility" },
          { icon: "📝", label: "Voice notes & dictation" },
        ].map((u) => (
          <div class="flex items-center gap-2.5 p-3 rounded-md bg-[var(--color-surface)] shadow-line">
            <span class="text-lg" aria-hidden="true">{u.icon}</span>
            <span class="text-sm text-[var(--color-fg-muted)]">{u.label}</span>
          </div>
        ))}
      </div>
    </section>

    {/* ─── FAQ ─── */}
    <section class="mt-20 max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl font-bold tracking-tight">Frequently asked</h2>
      <div class="mt-6 space-y-2">
        {faqJsonLd.mainEntity.map((q) => (
          <details class="group bg-[var(--color-surface)] rounded-md px-4 py-3 shadow-line">
            <summary class="cursor-pointer font-semibold text-[var(--color-fg)] flex items-center justify-between gap-3">
              <span>{q.name}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9" /></svg>
            </summary>
            <div class="mt-2 text-sm text-[var(--color-fg-muted)] [&_p]:mt-2 [&_p:first-child]:mt-0" set:html={q.acceptedAnswer.text}></div>
          </details>
        ))}
      </div>
    </section>

    {/* ─── Cross-promotion: sister tools at worksoffline.in ─── */}
    <CrossPromo />
  </main>
</Layout>
