---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";
---
<Layout title="Contact" description={`Contact ${site.name}`}>
  <main class="max-w-3xl mx-auto px-4 sm:px-6 pt-10 pb-16">
    <h1 class="text-3xl font-bold tracking-tight">Contact</h1>
    <div class="mt-6 space-y-5 text-[var(--color-fg-muted)] text-[15px] leading-relaxed">
      <p>
        For bug reports, feature requests, partnership inquiries, or anything else:
      </p>
      <ul class="space-y-3">
        <li>
          <strong class="text-[var(--color-fg)]">Email</strong> —
          <a class="underline" href={`mailto:${site.contactEmail}?subject=${encodeURIComponent(`${site.name} —`)}`}>{site.contactEmail}</a>
        </li>
        {site.githubUrl && (
          <li>
            <strong class="text-[var(--color-fg)]">GitHub Issues</strong> —
            <a class="underline" href={`${site.githubUrl}/issues`}>{site.githubUrl}/issues</a>
            <span class="block text-sm mt-1">Preferred for technical bug reports and feature requests.</span>
          </li>
        )}
        <li>
          <strong class="text-[var(--color-fg)]">Security disclosure</strong> —
          <a class="underline" href={`mailto:${site.contactEmail}?subject=${encodeURIComponent(`${site.name} security`)}`}>{site.contactEmail}</a> with subject "{site.name} security".
        </li>
      </ul>
      <p>
        Typical response time: 1–3 business days. {site.name} is built and maintained by a single developer in {site.jurisdiction}.
      </p>
    </div>
  </main>
</Layout>
