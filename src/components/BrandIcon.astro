---
interface Props {
  size?: number;
  class?: string;
}
const { size = 32, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 32 32"
  class={className}
  aria-hidden="true"
>
  <defs>
    <linearGradient id="cp-brand-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="oklch(78% 0.14 200)" />
      <stop offset="100%" stop-color="oklch(60% 0.16 200)" />
    </linearGradient>
  </defs>
  {/* Main speech bubble — slightly rounded square with tail */}
  <path
    d="M 4 6
       Q 4 3, 7 3
       L 22 3
       Q 25 3, 25 6
       L 25 16
       Q 25 19, 22 19
       L 13 19
       L 9 23
       L 9 19
       L 7 19
       Q 4 19, 4 16
       Z"
    fill="url(#cp-brand-grad)"
  />
  {/* PiP mini bubble — sits in the lower-right corner of the main bubble */}
  <rect
    x="17" y="20"
    width="12" height="9"
    rx="2.5"
    fill="oklch(60% 0.16 200)"
  />
  <rect
    x="17" y="20"
    width="12" height="9"
    rx="2.5"
    fill="none"
    stroke="white"
    stroke-width="1.5"
    stroke-opacity="0.4"
  />
  {/* Caption lines inside main bubble */}
  <g stroke="white" stroke-linecap="round" stroke-width="1.6">
    <line x1="8" y1="8.5" x2="20" y2="8.5" opacity="0.95" />
    <line x1="8" y1="12" x2="17" y2="12" opacity="0.75" />
    <line x1="8" y1="15.5" x2="14" y2="15.5" opacity="0.55" />
  </g>
</svg>
