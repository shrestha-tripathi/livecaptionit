---
import { site, b } from "../site.config";
import BrandIcon from "./BrandIcon.astro";

const year = new Date().getFullYear();
---

<footer class="mt-24 py-10">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row gap-6 sm:gap-12 sm:items-start">
      <div class="flex items-center gap-2 text-[var(--color-fg)]">
        <BrandIcon size={22} />
        <span class="font-semibold tracking-tight text-sm">{site.shortName}</span>
      </div>
      <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
        <a href={b("/about")} class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">About</a>
        <a href={b("/privacy")} class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">Privacy</a>
        <a href={b("/terms")} class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">Terms</a>
        <a href={b("/contact")} class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">Contact</a>
        <a href={b("/disclaimer")} class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">Disclaimer</a>
        {site.githubUrl && <a href={site.githubUrl} target="_blank" rel="noopener noreferrer" class="text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors">GitHub</a>}
      </div>
    </div>
    <p class="mt-6 text-xs text-[var(--color-fg-subtle)]">
      © {year} {site.author} · {site.name} runs Whisper locally in your browser via WebGPU. Audio never uploads.
    </p>
  </div>
</footer>
