---
/*
  The actual capture UI. This is mostly an Astro shell of markup —
  the orchestration logic lives in CaptionApp.script.ts.
*/
---

<section
  id="caption-app"
  class="w-full max-w-3xl mx-auto px-4 sm:px-6"
  data-state="idle"
>
  {/* ────────────── IDLE PANEL ────────────── */}
  <div data-panel="idle" class="text-center py-8 sm:py-12">
    <button
      id="cp-start-btn"
      type="button"
      class="brand-halo inline-flex items-center gap-2.5 px-6 py-3.5 rounded-full text-base font-semibold bg-[var(--color-brand)] text-white hover:bg-[var(--color-brand-strong)] transition-colors shadow-line"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="5,3 21,12 5,21" fill="currentColor" stroke="none" />
      </svg>
      Start captions
    </button>
    <p class="mt-3.5 text-xs text-[var(--color-fg-subtle)]">
      Opens a floating window that stays on top of any app. Audio processed locally — never uploads.
    </p>
    <div class="mt-4 flex justify-center">
      <label
        id="cp-inline-toggle-wrap"
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs text-[var(--color-fg-muted)] cursor-pointer select-none shadow-line hover:bg-[var(--color-surface)] transition-colors"
      >
        <input
          id="cp-inline-toggle"
          type="checkbox"
          class="size-3.5 accent-[var(--color-brand)] cursor-pointer"
        />
        Show captions in this tab instead
      </label>
    </div>

    {/* ── Floating-window preferences (collapsible) ── */}
    <details
      id="cp-prefs"
      class="mt-5 max-w-md mx-auto text-left rounded-lg bg-[var(--color-surface)] shadow-line group"
    >
      <summary class="cursor-pointer select-none px-4 py-2.5 text-xs font-semibold uppercase tracking-wider text-[var(--color-fg-muted)] flex items-center justify-between">
        <span class="inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M14 21h-4M12 17v4"/></svg>
          Floating window
        </span>
        <svg class="transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="px-4 pb-4 pt-1 space-y-3.5">

        {/* Width */}
        <div>
          <div class="flex items-center justify-between text-xs">
            <label for="cp-pref-width" class="text-[var(--color-fg-muted)]">Width</label>
            <span id="cp-pref-width-val" class="font-mono text-[var(--color-fg)] tabular-nums">480 px</span>
          </div>
          <input
            id="cp-pref-width"
            type="range"
            min="320" max="900" step="20" value="480"
            class="mt-1.5 w-full accent-[var(--color-brand)]"
          />
        </div>

        {/* Height */}
        <div>
          <div class="flex items-center justify-between text-xs">
            <label for="cp-pref-height" class="text-[var(--color-fg-muted)]">Height</label>
            <span id="cp-pref-height-val" class="font-mono text-[var(--color-fg)] tabular-nums">260 px</span>
          </div>
          <input
            id="cp-pref-height"
            type="range"
            min="160" max="600" step="10" value="260"
            class="mt-1.5 w-full accent-[var(--color-brand)]"
          />
        </div>

        {/* Opacity */}
        <div>
          <div class="flex items-center justify-between text-xs">
            <label for="cp-pref-opacity" class="text-[var(--color-fg-muted)]">Background opacity</label>
            <span id="cp-pref-opacity-val" class="font-mono text-[var(--color-fg)] tabular-nums">100%</span>
          </div>
          <input
            id="cp-pref-opacity"
            type="range"
            min="20" max="100" step="5" value="100"
            class="mt-1.5 w-full accent-[var(--color-brand)]"
          />
          <p class="mt-1 text-[10px] text-[var(--color-fg-subtle)] leading-snug">
            Lower = see the video through the caption box. Text stays readable; controls fade in on hover.
          </p>
        </div>

        <div class="flex items-center justify-between gap-2 pt-1">
          <p class="text-[10px] text-[var(--color-fg-subtle)] leading-snug">
            Browsers decide initial window position. Drag the window to move it; size + opacity persist.
          </p>
          <button
            id="cp-pref-reset"
            type="button"
            class="shrink-0 text-[10px] uppercase tracking-wider font-semibold px-2 py-1 rounded-md text-[var(--color-fg-muted)] hover:bg-[var(--color-surface-strong)] transition-colors"
            title="Reset to defaults"
          >Reset</button>
        </div>
      </div>
    </details>

    <div id="cp-support-warn" class="hidden mt-5 px-4 py-3 rounded-md bg-[var(--color-surface)] text-sm text-[var(--color-fg-muted)] shadow-line"></div>
  </div>

  {/* ────────────── LOADING PANEL ────────────── */}
  <div data-panel="loading" class="hidden py-10 text-center">
    <div class="inline-flex items-center gap-3 text-sm text-[var(--color-fg-muted)]">
      <span class="size-2 rounded-full bg-[var(--color-brand)] rec-dot"></span>
      <span id="cp-loading-msg">Preparing…</span>
    </div>
    <div class="mt-4 max-w-md mx-auto h-1 rounded-full bg-[var(--color-surface)] overflow-hidden">
      <div id="cp-loading-bar" class="h-full bg-[var(--color-brand)] transition-all" style="width: 0%"></div>
    </div>
  </div>

  {/* ────────────── ACTIVE PANEL ────────────── */}
  <div data-panel="active" class="hidden">
    {/* Mount point — caption box can be moved INTO PiP and back to here */}
    <div id="cp-caption-mount">
      <div id="cp-caption-box" class="cp-caption-box bg-[var(--color-surface)] rounded-xl shadow-line flex flex-col h-[260px]">
        {/* Sticky header — controls stay visible no matter how many caption lines accrue */}
        <header class="shrink-0 flex items-center justify-between gap-3 px-5 pt-4 pb-3 border-b border-[var(--color-surface-strong)]">
          <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider">
            <span class="size-2 rounded-full bg-[var(--color-rec)] rec-dot"></span>
            <span style="color: var(--color-rec)">LIVE</span>
            <span class="text-[var(--color-fg-subtle)] font-normal normal-case tracking-normal truncate max-w-[180px]" id="cp-source-label"></span>
          </div>
          <div class="flex items-center gap-1.5 shrink-0">
            <button
              id="cp-pip-btn"
              type="button"
              class="text-[10px] uppercase tracking-wider font-semibold px-2.5 py-1 rounded-md bg-[var(--color-surface-strong)] hover:bg-[var(--color-brand)] hover:text-white transition-colors shadow-line"
              title="Toggle floating window"
            >Pop out</button>
            <button
              id="cp-stop-btn"
              type="button"
              class="text-[10px] uppercase tracking-wider font-semibold px-2.5 py-1 rounded-md bg-[var(--color-surface-strong)] hover:bg-[var(--color-rec)] hover:text-white transition-colors shadow-line"
              title="Stop captioning"
            >Stop</button>
          </div>
        </header>

        {/* Status banner — visible inside both main mount AND PiP window
            (same DOM node, moves with the caption box). Hidden once
            the first real caption arrives. */}
        <div id="cp-caption-status" class="hidden shrink-0 mx-5 mt-3 px-3 py-2 rounded-md bg-[var(--color-surface-strong)]">
          <div class="flex items-center gap-2 text-xs text-[var(--color-fg-muted)]">
            <span class="size-1.5 rounded-full bg-[var(--color-brand)] rec-dot"></span>
            <span id="cp-caption-status-msg">Loading…</span>
          </div>
          <div class="mt-2 h-0.5 rounded-full bg-[var(--color-surface)] overflow-hidden">
            <div id="cp-caption-status-bar" class="hidden h-full bg-[var(--color-brand)] transition-all" style="width: 0%"></div>
          </div>
        </div>

        {/* Scrollable caption history — committed text + live (uncommitted) tail
            flow as ONE continuous stream. Live tail is a muted span at the
            end of the current paragraph. No visual panel split. */}
        <div
          id="cp-caption-stream"
          class="caption-text text-[var(--color-fg)] flex-1 min-h-0 overflow-y-auto px-5 py-3"
          aria-live="polite"
          aria-atomic="false"
        >
          <p class="text-[var(--color-fg-subtle)] text-sm italic font-normal">Listening… first word usually appears within ~1 second.</p>
        </div>
      </div>
    </div>
    <p class="mt-3 text-xs text-[var(--color-fg-subtle)] text-center">
      Bold text = confirmed. Muted text at the end = still being heard.
    </p>
  </div>

  {/* ────────────── ERROR PANEL ────────────── */}
  <div data-panel="error" class="hidden py-10 text-center">
    <div class="inline-flex items-start gap-2 max-w-md text-left px-4 py-3 rounded-md bg-[var(--color-surface)] shadow-line">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-rec)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
      <div>
        <p class="font-semibold text-sm" style="color: var(--color-rec)">Something went wrong</p>
        <p id="cp-error-msg" class="mt-1 text-sm text-[var(--color-fg-muted)]"></p>
      </div>
    </div>
    <button
      id="cp-reset-btn"
      type="button"
      class="mt-4 text-xs uppercase tracking-wider font-semibold px-3 py-1.5 rounded-md bg-[var(--color-surface)] hover:bg-[var(--color-surface-strong)] transition-colors shadow-line"
    >Try again</button>
  </div>

  {/* Hidden placeholder shown in MAIN page when caption box is currently inside PiP */}
  <div id="cp-pip-placeholder" class="hidden py-8 text-center text-sm text-[var(--color-fg-subtle)] italic">
    Captions are showing in the floating window. Close it to bring them back here.
  </div>
</section>

<script src="./CaptionApp.script.ts"></script>
