---
/*
  The actual capture UI. This is mostly an Astro shell of markup —
  the orchestration logic lives in CaptionApp.script.ts.
*/
---

<section
  id="caption-app"
  class="w-full max-w-3xl mx-auto px-4 sm:px-6"
  data-state="idle"
>
  {/* ────────────── IDLE PANEL ────────────── */}
  <div data-panel="idle" class="text-center py-8 sm:py-12">
    <button
      id="cp-start-btn"
      type="button"
      class="brand-halo inline-flex items-center gap-2.5 px-6 py-3.5 rounded-full text-base font-semibold bg-[var(--color-brand)] text-white hover:bg-[var(--color-brand-strong)] transition-colors shadow-line"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="5,3 21,12 5,21" fill="currentColor" stroke="none" />
      </svg>
      Start captions
    </button>
    <p class="mt-3.5 text-xs text-[var(--color-fg-subtle)]">
      Opens a floating window that stays on top of any app. Audio processed locally — never uploads.
    </p>

    {/* Source toggle — tab/window vs microphone */}
    <div class="mt-4 flex justify-center">
      <div class="inline-flex items-center gap-1 p-1 rounded-full bg-[var(--color-surface)] shadow-line">
        <label class="cp-segment-radio">
          <input type="radio" name="cp-source-toggle" value="tab" checked />
          <span class="inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Tab / window
          </span>
        </label>
        <label class="cp-segment-radio">
          <input type="radio" name="cp-source-toggle" value="mic" />
          <span class="inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
            Microphone
          </span>
        </label>
      </div>
    </div>

    {/* ── Try with sample audio (no permission prompt) ── */}
    <div class="mt-3 flex justify-center">
      <button
        id="cp-sample-btn"
        type="button"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium text-[var(--color-fg-muted)] bg-[var(--color-surface)] hover:bg-[var(--color-surface-strong)] transition-colors shadow-line"
        title="Plays a bundled audio clip through the same pipeline — no permission prompts"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 19 22 12 13 5 13 19"/><polygon points="2 19 11 12 2 5 2 19"/></svg>
        Try with sample audio · no setup
      </button>
    </div>
    {/* Hidden audio element used by sampleFeed to play sample through speakers */}
    <audio id="cp-sample-audio" preload="none" aria-hidden="true" class="hidden"></audio>

    {/* ── Recent sessions (v0.4.0 — populated by script.ts on mount) ── */}
    <div
      id="cp-history-panel"
      class="hidden mt-6 max-w-md mx-auto text-left rounded-lg bg-[var(--color-surface)] shadow-line"
    >
      <header class="px-4 py-2.5 text-xs font-semibold uppercase tracking-wider text-[var(--color-fg-muted)] flex items-center justify-between border-b border-[var(--color-border)]">
        <span class="inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/><path d="M12 7v5l3 2"/></svg>
          Recent sessions
        </span>
        <button
          id="cp-history-clear"
          type="button"
          class="text-[10px] font-normal normal-case tracking-normal text-[var(--color-fg-subtle)] hover:text-[var(--color-fg-muted)] transition-colors"
        >Clear all</button>
      </header>
      <ul id="cp-history-list" class="divide-y divide-[var(--color-border)]">
        {/* Filled dynamically by CaptionApp.script.ts */}
      </ul>
    </div>

    <div class="mt-4 flex justify-center">
      <label
        id="cp-inline-toggle-wrap"
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs text-[var(--color-fg-muted)] cursor-pointer select-none shadow-line hover:bg-[var(--color-surface)] transition-colors"
      >
        <input
          id="cp-inline-toggle"
          type="checkbox"
          class="size-3.5 accent-[var(--color-brand)] cursor-pointer"
        />
        Show captions in this tab instead
      </label>
    </div>

    {/* ── Model picker (collapsible) ── */}
    <details
      id="cp-model-prefs"
      class="mt-3 max-w-md mx-auto text-left rounded-lg bg-[var(--color-surface)] shadow-line group"
    >
      <summary class="cursor-pointer select-none px-4 py-2.5 text-xs font-semibold uppercase tracking-wider text-[var(--color-fg-muted)] flex items-center justify-between">
        <span class="inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
          Whisper model
        </span>
        <svg class="transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div id="cp-model-list" class="px-2 pb-3 pt-1 space-y-1">
        {/* Filled dynamically by CaptionApp.script.ts so we can show cache
            indicators (✓ / ⬇) and select-on-click without re-rendering server-side. */}
      </div>
      <p class="px-4 pb-3 text-[10px] text-[var(--color-fg-subtle)] leading-snug">
        Applies on next Start. Model files cache in your browser — first download is one-time.
      </p>
    </details>

    {/* ── Caption style (collapsible) ── */}
    <details
      id="cp-style-prefs"
      class="mt-3 max-w-md mx-auto text-left rounded-lg bg-[var(--color-surface)] shadow-line group"
    >
      <summary class="cursor-pointer select-none px-4 py-2.5 text-xs font-semibold uppercase tracking-wider text-[var(--color-fg-muted)] flex items-center justify-between">
        <span class="inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
          Caption style
        </span>
        <svg class="transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="px-4 pb-4 pt-1 space-y-3.5">

        {/* Font size */}
        <div>
          <div class="flex items-center justify-between text-xs">
            <label for="cp-style-fontscale" class="text-[var(--color-fg-muted)]">Font size</label>
            <span id="cp-style-fontscale-val" class="font-mono text-[var(--color-fg)] tabular-nums">100%</span>
          </div>
          <input
            id="cp-style-fontscale"
            type="range"
            min="80" max="200" step="5" value="100"
            class="mt-1.5 w-full accent-[var(--color-brand)]"
          />
        </div>

        {/* Font weight */}
        <div>
          <div class="flex items-center justify-between text-xs">
            <label for="cp-style-fontweight" class="text-[var(--color-fg-muted)]">Base weight</label>
          </div>
          <div class="mt-1.5 grid grid-cols-3 gap-1.5">
            <label class="cp-pill-radio">
              <input type="radio" name="cp-style-fontweight" value="400" checked />
              <span>Regular</span>
            </label>
            <label class="cp-pill-radio">
              <input type="radio" name="cp-style-fontweight" value="500" />
              <span>Medium</span>
            </label>
            <label class="cp-pill-radio">
              <input type="radio" name="cp-style-fontweight" value="600" />
              <span>Bold</span>
            </label>
          </div>
        </div>

        {/* Caption position in PiP */}
        <div>
          <div class="flex items-center justify-between text-xs">
            <label class="text-[var(--color-fg-muted)]">Position in caption box</label>
          </div>
          <div class="mt-1.5 grid grid-cols-3 gap-1.5">
            <label class="cp-pill-radio">
              <input type="radio" name="cp-style-position" value="top" checked />
              <span>Top</span>
            </label>
            <label class="cp-pill-radio">
              <input type="radio" name="cp-style-position" value="middle" />
              <span>Middle</span>
            </label>
            <label class="cp-pill-radio">
              <input type="radio" name="cp-style-position" value="bottom" />
              <span>Bottom</span>
            </label>
          </div>
        </div>

        {/* Text shadow toggle */}
        <label
          class="flex items-center justify-between gap-2 text-xs cursor-pointer select-none px-2 py-1.5 rounded-md hover:bg-[var(--color-surface-strong)] transition-colors"
        >
          <span class="text-[var(--color-fg-muted)]">Text shadow <span class="text-[var(--color-fg-subtle)] normal-case font-normal">(legibility over bright video)</span></span>
          <input
            id="cp-style-shadow"
            type="checkbox"
            class="size-3.5 accent-[var(--color-brand)] cursor-pointer"
            checked
          />
        </label>

        <div class="flex items-center justify-between gap-2 pt-1">
          <p class="text-[10px] text-[var(--color-fg-subtle)] leading-snug">
            Live-applies. Saved to your browser only.
          </p>
          <button
            id="cp-style-reset"
            type="button"
            class="shrink-0 text-[10px] uppercase tracking-wider font-semibold px-2 py-1 rounded-md text-[var(--color-fg-muted)] hover:bg-[var(--color-surface-strong)] transition-colors"
            title="Reset to defaults"
          >Reset</button>
        </div>
      </div>
    </details>
    <details
      id="cp-prefs"
      class="mt-5 max-w-md mx-auto text-left rounded-lg bg-[var(--color-surface)] shadow-line group"
    >
      <summary class="cursor-pointer select-none px-4 py-2.5 text-xs font-semibold uppercase tracking-wider text-[var(--color-fg-muted)] flex items-center justify-between">
        <span class="inline-flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M14 21h-4M12 17v4"/></svg>
          Floating window size
        </span>
        <svg class="transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="px-4 pb-4 pt-1 space-y-3.5">

        {/* Width — % of screen */}
        <div>
          <div class="flex items-center justify-between text-xs">
            <label for="cp-pref-width" class="text-[var(--color-fg-muted)]">Width</label>
            <span id="cp-pref-width-val" class="font-mono text-[var(--color-fg)] tabular-nums">60%</span>
          </div>
          <input
            id="cp-pref-width"
            type="range"
            min="15" max="100" step="5" value="60"
            class="mt-1.5 w-full accent-[var(--color-brand)]"
          />
        </div>

        {/* Height — % of screen */}
        <div>
          <div class="flex items-center justify-between text-xs">
            <label for="cp-pref-height" class="text-[var(--color-fg-muted)]">Height</label>
            <span id="cp-pref-height-val" class="font-mono text-[var(--color-fg)] tabular-nums">18%</span>
          </div>
          <input
            id="cp-pref-height"
            type="range"
            min="10" max="80" step="2" value="18"
            class="mt-1.5 w-full accent-[var(--color-brand)]"
          />
        </div>

        <p id="cp-pref-pixels" class="text-[10px] text-[var(--color-fg-subtle)] font-mono tabular-nums">
          ≈ 0 × 0 px at current screen size
        </p>

        <div class="flex items-center justify-between gap-2 pt-1">
          <p class="text-[10px] text-[var(--color-fg-subtle)] leading-snug">
            Tip: set Width to 100% for an edge-to-edge subtitle bar. Browsers decide initial position; drag to move.
          </p>
          <button
            id="cp-pref-reset"
            type="button"
            class="shrink-0 text-[10px] uppercase tracking-wider font-semibold px-2 py-1 rounded-md text-[var(--color-fg-muted)] hover:bg-[var(--color-surface-strong)] transition-colors"
            title="Reset to defaults"
          >Reset</button>
        </div>
      </div>
    </details>

    <div id="cp-support-warn" class="hidden mt-5 px-4 py-3 rounded-md bg-[var(--color-surface)] text-sm text-[var(--color-fg-muted)] shadow-line"></div>
  </div>

  {/* ────────────── LOADING PANEL ────────────── */}
  <div data-panel="loading" class="hidden py-10 text-center">
    <div class="inline-flex items-center gap-3 text-sm text-[var(--color-fg-muted)]">
      <span class="size-2 rounded-full bg-[var(--color-brand)] rec-dot"></span>
      <span id="cp-loading-msg">Preparing…</span>
    </div>
    <div class="mt-4 max-w-md mx-auto h-1 rounded-full bg-[var(--color-surface)] overflow-hidden">
      <div id="cp-loading-bar" class="h-full bg-[var(--color-brand)] transition-all" style="width: 0%"></div>
    </div>
  </div>

  {/* ────────────── ACTIVE PANEL ────────────── */}
  <div data-panel="active" class="hidden">
    {/* Mount point — caption box can be moved INTO PiP and back to here */}
    <div id="cp-caption-mount">
      <div id="cp-caption-box" class="cp-caption-box bg-[var(--color-surface)] rounded-xl shadow-line flex flex-col h-[260px]">
        {/* Sticky header — controls stay visible no matter how many caption lines accrue */}
        <header class="shrink-0 flex items-center justify-between gap-3 px-5 pt-4 pb-3 border-b border-[var(--color-surface-strong)]">
          <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider">
            {/* Live indicator — visible only in live substate.
                Note: we DON'T set `inline-flex` here because Tailwind's
                `.hidden` (display:none) only wins over baseline `display`
                when no other display utility competes. Style with
                arbitrary `[display:inline-flex]` so the substate toggle
                via `.hidden` works correctly. */}
            <span data-when="live" class="items-center gap-2 [display:inline-flex]">
              <span class="size-2 rounded-full bg-[var(--color-rec)] rec-dot"></span>
              <span style="color: var(--color-rec)">LIVE</span>
            </span>
            {/* Paused indicator (v0.4.1) — visible only in paused substate.
                Static dot (no pulse animation) so it reads as "frozen". */}
            <span data-when="paused" class="hidden items-center gap-2 [display:inline-flex]">
              <span class="size-2 rounded-full bg-[var(--color-fg-muted)]"></span>
              <span style="color: var(--color-fg-muted)">PAUSED</span>
            </span>
            {/* Stopped indicator — visible only in stopped substate (after Stop while transcript has content) */}
            <span data-when="stopped" class="hidden items-center gap-2 [display:inline-flex]">
              <span class="size-2 rounded-full bg-[var(--color-fg-subtle)]"></span>
              <span style="color: var(--color-fg-muted)">STOPPED</span>
            </span>
            <span class="text-[var(--color-fg-subtle)] font-normal normal-case tracking-normal truncate max-w-[180px]" id="cp-source-label"></span>
          </div>
          <div class="flex items-center gap-1.5 shrink-0">
            <button
              id="cp-pip-btn"
              data-when="live paused"
              type="button"
              class="text-[10px] uppercase tracking-wider font-semibold px-2.5 py-1 rounded-md bg-[var(--color-surface-strong)] hover:bg-[var(--color-brand)] hover:text-white transition-colors shadow-line"
              title="Toggle floating window"
            >Pop out</button>
            {/* "Start new" appears only after Stop so users have an obvious next action */}
            <button
              id="cp-restart-btn"
              data-when="stopped"
              type="button"
              class="hidden text-[10px] uppercase tracking-wider font-semibold px-2.5 py-1 rounded-md bg-[var(--color-brand)] text-white hover:bg-[var(--color-brand-strong)] transition-colors shadow-line"
              title="Start a new session"
            >Start new</button>
            {/* Stop button: in live substate says "Stop" + stops capture.
                In stopped substate becomes "Done" + clears + returns to idle. */}
            <button
              id="cp-stop-btn"
              type="button"
              class="text-[10px] uppercase tracking-wider font-semibold px-2.5 py-1 rounded-md bg-[var(--color-surface-strong)] hover:bg-[var(--color-rec)] hover:text-white transition-colors shadow-line"
              title="Stop captioning"
            ><span data-when="live paused">Stop</span><span data-when="stopped" class="hidden">Done</span></button>
          </div>
        </header>

        {/* Status banner — visible inside both main mount AND PiP window
            (same DOM node, moves with the caption box). Hidden once
            the first real caption arrives. */}
        <div id="cp-caption-status" class="hidden shrink-0 mx-5 mt-3 px-3 py-2 rounded-md bg-[var(--color-surface-strong)]">
          <div class="flex items-center gap-2 text-xs text-[var(--color-fg-muted)]">
            <span class="size-1.5 rounded-full bg-[var(--color-brand)] rec-dot"></span>
            <span id="cp-caption-status-msg">Loading…</span>
          </div>
          <div class="mt-2 h-0.5 rounded-full bg-[var(--color-surface)] overflow-hidden">
            <div id="cp-caption-status-bar" class="hidden h-full bg-[var(--color-brand)] transition-all" style="width: 0%"></div>
          </div>
        </div>

        {/* Scrollable caption history — committed text + live (uncommitted) tail
            flow as ONE continuous stream. Live tail is a muted span at the
            end of the current paragraph. No visual panel split.
            Flex column so the caption-position-{top|middle|bottom} class
            controls vertical alignment of the content within the scroller. */}
        <div
          id="cp-caption-stream"
          class="caption-text text-[var(--color-fg)] flex-1 min-h-0 overflow-y-auto px-5 py-3 flex flex-col caption-position-top"
          aria-live="polite"
          aria-atomic="false"
        >
          <p class="text-[var(--color-fg-subtle)] text-sm italic font-normal">Listening… first word usually appears within ~1 second.</p>
        </div>
      </div>
    </div>
    <p class="mt-3 text-xs text-[var(--color-fg-subtle)] text-center">
      Bold text = confirmed. Muted text at the end = still being heard.
    </p>

    {/* Download transcript buttons — only visible after Stop when we have
        a recorded transcript. Filled + shown by CaptionApp.script.ts. */}
    <div id="cp-download-bar" class="hidden mt-4 flex flex-col items-center gap-2">
      <p class="text-xs text-[var(--color-fg-muted)]">Save the transcript:</p>
      <div class="inline-flex items-center gap-1.5">
        <button
          id="cp-dl-txt"
          type="button"
          class="text-xs font-semibold px-3 py-1.5 rounded-md bg-[var(--color-surface)] hover:bg-[var(--color-brand)] hover:text-white transition-colors shadow-line"
        >.txt</button>
        <button
          id="cp-dl-vtt"
          type="button"
          class="text-xs font-semibold px-3 py-1.5 rounded-md bg-[var(--color-surface)] hover:bg-[var(--color-brand)] hover:text-white transition-colors shadow-line"
          title="WebVTT — for video players that support subtitles"
        >.vtt</button>
        <button
          id="cp-dl-srt"
          type="button"
          class="text-xs font-semibold px-3 py-1.5 rounded-md bg-[var(--color-surface)] hover:bg-[var(--color-brand)] hover:text-white transition-colors shadow-line"
          title="SubRip — universal subtitle format"
        >.srt</button>
        <button
          id="cp-dl-clear"
          type="button"
          class="text-xs font-semibold px-3 py-1.5 rounded-md text-[var(--color-fg-muted)] hover:bg-[var(--color-surface-strong)] transition-colors"
          title="Clear transcript and return to start screen"
        >Clear</button>
      </div>
      <p class="text-[10px] text-[var(--color-fg-subtle)]">
        Timestamps are segment-level (~600-1200ms granularity), not word-level.
      </p>
    </div>
  </div>

  {/* ────────────── ERROR PANEL ────────────── */}
  <div data-panel="error" class="hidden py-10 text-center">
    <div class="inline-flex items-start gap-2 max-w-md text-left px-4 py-3 rounded-md bg-[var(--color-surface)] shadow-line">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-rec)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
      <div>
        <p class="font-semibold text-sm" style="color: var(--color-rec)">Something went wrong</p>
        <p id="cp-error-msg" class="mt-1 text-sm text-[var(--color-fg-muted)]"></p>
      </div>
    </div>
    <button
      id="cp-reset-btn"
      type="button"
      class="mt-4 text-xs uppercase tracking-wider font-semibold px-3 py-1.5 rounded-md bg-[var(--color-surface)] hover:bg-[var(--color-surface-strong)] transition-colors shadow-line"
    >Try again</button>
  </div>

  {/* Hidden placeholder shown in MAIN page when caption box is currently inside PiP */}
  <div id="cp-pip-placeholder" class="hidden py-8 text-center text-sm text-[var(--color-fg-subtle)] italic">
    Captions are showing in the floating window. Close it to bring them back here.
  </div>

  {/* ── Keyboard shortcuts help (v0.4.0) ── */}
  <dialog
    id="cp-shortcuts-help"
