---
import { site, b } from "../site.config";
import BrandIcon from "./BrandIcon.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<nav class="sticky top-0 z-30 bg-[var(--color-bg)]/85 backdrop-blur-md">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <a href={b("/")} class="flex items-center gap-2 text-[var(--color-fg)] hover:opacity-80 transition-opacity" aria-label={`${site.name} home`}>
      <BrandIcon size={28} />
      <span class="font-semibold tracking-tight text-base">{site.shortName}</span>
    </a>
    <div class="flex items-center gap-2">
      <a
        href={b("/about")}
        class="hidden sm:inline-flex h-9 items-center px-3 rounded-md text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] transition-colors"
      >About</a>
      {site.githubUrl && (
        <a
          href={site.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="size-9 grid place-items-center rounded-md bg-[var(--color-surface)] hover:bg-[var(--color-surface-strong)] transition-colors shadow-line"
          aria-label="GitHub repo"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.69-3.88-1.36-3.88-1.36-.52-1.32-1.28-1.67-1.28-1.67-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.74.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.3-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11.07 11.07 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.06.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.4-5.25 5.69.41.35.78 1.04.78 2.11v3.13c0 .31.21.66.8.55 4.56-1.52 7.85-5.83 7.85-10.91C23.5 5.65 18.35.5 12 .5z"/></svg>
        </a>
      )}
      <ThemeToggle />
    </div>
  </div>
</nav>
