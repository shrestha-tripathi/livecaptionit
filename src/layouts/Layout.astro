---
import "../styles/global.css";
import { site, absoluteUrl } from "../site.config";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: object[];
}

const {
  title,
  description = site.description,
  ogImage = "/og-image.png",
  noindex = false,
  jsonLd = [],
} = Astro.props;

const fullTitle = title ? `${title} · ${site.name}` : `${site.name} — ${site.tagline}`;
const canonical = absoluteUrl(Astro.url.pathname);
const ogUrl = absoluteUrl(ogImage);

const baseJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${site.url}/#organization`,
    name: site.name,
    url: site.url,
    logo: absoluteUrl("/favicon.svg"),
    description: site.description,
    founder: { "@type": "Person", name: site.author },
    sameAs: site.githubUrl ? [site.githubUrl] : [],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${site.url}/#website`,
    url: site.url,
    name: site.name,
    description: site.description,
    publisher: { "@id": `${site.url}/#organization` },
    inLanguage: site.locale,
  },
];

// Auto-breadcrumb for every non-home page: Home → <title>. Derived from the
// title prop + canonical the page already passes in, so no per-page wiring is
// needed (DRY — one edit covers all routes). Skipped on the homepage (no
// title) where a single-item breadcrumb would be noise.
const breadcrumbJsonLd =
  title && Astro.url.pathname !== "/"
    ? [
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          itemListElement: [
            { "@type": "ListItem", position: 1, name: "Home", item: absoluteUrl("/") },
            { "@type": "ListItem", position: 2, name: title, item: canonical },
          ],
        },
      ]
    : [];

const allJsonLd = [...baseJsonLd, ...breadcrumbJsonLd, ...jsonLd];
---

<!doctype html>
<html lang={site.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    {import.meta.env.PROD && site.gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${site.gaId}`}></script>
        <script is:inline define:vars={{ gaId: site.gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#ffffff" id="theme-color-meta" />

    {/* DNS prefetch + preconnect to jsDelivr — Whisper worker pulls
        transformers.js from there on first model load. Prewarming the
        TCP/TLS handshake saves ~200-400ms before the user even clicks
        Start (cheap idle-time hint, won't fetch any payload). */}
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

    {/* Prefetch the Whisper worker JS file at low priority on the home
        page (where the Start button is) so the file is in HTTP cache by
        the time the user clicks. The worker is only INSTANTIATED on
        Start — prefetching just pulls the bytes early. ~8KB. Skipped
        on every other page (about, contact, etc.) where it's wasted
        bandwidth. */}
    {Astro.url.pathname === "/" && (
      <link rel="prefetch" href="/whisper-worker.js" as="worker" />
    )}

    {/* Geist + Geist Mono via Google Fonts.

        Two-line non-blocking pattern:
         1. `rel="preload" as="style"` starts fetching the CSS without
            blocking render.
         2. The `onload="this.rel='stylesheet'"` swap promotes the
            preload to a real stylesheet once it's loaded — so text
            paints in fallback fonts immediately, then re-paints with
            Geist when ready. No layout shift because Geist + system-ui
            have similar metrics, and `font-display: swap` is already
            in the Google CSS payload.
         3. `<noscript>` fallback for JS-disabled clients keeps the
            font working there too (just blocks render — same as before).
        Net: First Contentful Paint typically ~400-600ms earlier on slow
        connections (no longer waits for fonts.googleapis.com round-trip).
        Reference: https://web.dev/articles/defer-non-critical-css */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      id="cp-font-stylesheet"
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap"
    />
    <script is:inline>
      // Promote the font preload to a real stylesheet once it's loaded.
      // Kept out of the inline onload= attribute so astro-check doesn't
      // false-positive on TS-as-JSX parsing of `this.onload=null;this.rel=...`.
      (function () {
        var l = document.getElementById("cp-font-stylesheet");
        if (!l) return;
        l.addEventListener("load", function once() {
          l.removeEventListener("load", once);
          l.rel = "stylesheet";
        });
      })();
    </script>
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    </noscript>

    {/* OG / Twitter */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:alt" content={`${site.name} — ${site.tagline}`} />
    <meta property="og:site_name" content={site.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogUrl} />

    {allJsonLd.map((d) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(d)} />
    ))}

    {/* FOUC-free theme bootstrap — runs synchronously BEFORE any CSS loads.
        Default is LIGHT (no data-theme attribute = light theme). */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("livecaptionit:theme");
          var theme = stored === "light" || stored === "dark"
            ? stored
            : (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
          if (theme === "dark") {
            document.documentElement.setAttribute("data-theme", "dark");
          } else {
            document.documentElement.removeAttribute("data-theme");
          }
          var meta = document.getElementById("theme-color-meta");
          if (meta) {
            meta.setAttribute("content", theme === "dark" ? "#0a0a0a" : "#ffffff");
          }
        } catch (e) {}
      })();
    </script>

    {/* Service worker registration — enables PWA install prompt.
        See public/sw.js for why this is install-only (no offline caching). */}
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("/sw.js").catch(function (err) {
            console.warn("[SW] registration failed:", err);
          });
        });
      }
    </script>
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
  </body>
</html>
